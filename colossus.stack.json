{
  "certified": true,
  "components": {
    "backend": {
      "backend_probe_path": "/api/docs",
      "commands": {
        "test": "npm test -- --maxWorkers=2",
        "typecheck": "npx tsc --noEmit"
      },
      "display_name": "NestJS",
      "fingerprint_files": [
        "nest-cli.json"
      ],
      "id": "nestjs",
      "kind": "backend",
      "prompt_fragment": "stacks/enterprise/backend_agent.md",
      "root_candidates": [
        "backend"
      ],
      "schema_version": 1,
      "test_tuning": {
        "jest_max_workers": 2,
        "ts_jest_isolated_modules": true
      }
    },
    "frontend": {
      "browser_verify": {
        "notes": "hash-routed SPA: networkidle never fires; use getAllAngularTestabilities().every(t=>t.isStable())",
        "wait_strategy": "angular_testability"
      },
      "commands": {
        "build": "npx ng build --configuration production",
        "serve_dev": "npx ng serve"
      },
      "display_name": "Angular 19",
      "fingerprint_files": [
        "angular.json"
      ],
      "id": "angular19",
      "kind": "frontend",
      "prompt_fragment": "stacks/enterprise/ui_agent.md",
      "root_candidates": [
        "frontend",
        "web/frontend",
        "web"
      ],
      "schema_version": 1,
      "test_tuning": {
        "jest_max_workers": 2
      }
    },
    "orm": {
      "codegen_before_typecheck": [
        "npx prisma generate"
      ],
      "display_name": "Prisma",
      "id": "prisma",
      "kind": "orm",
      "migrate_deploy": "npx prisma migrate deploy",
      "prompt_fragment": "stacks/enterprise/db_agent.md",
      "schema_file_candidates": [
        "prisma/schema.prisma",
        "backend/prisma/schema.prisma"
      ],
      "schema_version": 1,
      "seed_path_candidates": [
        "prisma/seed/seed.js",
        "prisma/seed.js",
        "backend/prisma/seed/seed.js",
        "backend/prisma/seed.js"
      ]
    }
  },
  "display_name": "Enterprise (Angular 19 + NestJS + Prisma)",
  "docker_targets": [
    {
      "context": "backend",
      "dockerfile": "Dockerfile",
      "label": "backend"
    },
    {
      "context": "web",
      "dockerfile": "Dockerfile.frontend",
      "label": "frontend"
    }
  ],
  "glue": {
    "api_client": "trpc",
    "auth_pattern": "jwt_session",
    "frontend_api_base": "/api"
  },
  "known_good_dockerfiles": true,
  "notes": "Encodes the pre-multi-stack hardcoded behavior EXACTLY (P0 zero-behavior-change contract).",
  "resolved_schema_version": 1,
  "schema_version": 1,
  "serve_topology": "nginx_frontend_plus_backend_supervisor",
  "stack_id": "enterprise",
  "template_dir": "template-enterprise"
}
